{
  "expo": {
    "name": "TRAVI",
    "slug": "travi-superapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "travi",
    "splash": {
      "backgroundColor": "#0A0514"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.travi.superapp",
      "associatedDomains": [
        "applinks:travi.app",
        "applinks:*.travi.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0514"
      },
      "package": "com.travi.superapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "*.travi.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "travi"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      "@sentry/react-native",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.travi.app",
          "enableGooglePay": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#6443F4",
          "sounds": [],
          "defaultChannel": "default"
        }
      ],
      "expo-linking"
    ],
    "extra": {
      "eas": {
        "projectId": "86764fa4-f420-46ab-869a-5bbefcec9a42"
      }
    },
    "owner": "kbr_global"
  }
}